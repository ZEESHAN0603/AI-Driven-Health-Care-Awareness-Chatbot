    {
      "parameters": {
        "jsCode": "// Get chat + any existing DB row (from Supabase \"Get many rows\")\nconst chat = $node[\"When chat message received\"]?.json || {};\nconst supaItems = $node[\"Get many rows\"]?.json || {};\n\nconst userMessage = (chat.chatInput || chat.userMessage || \"\").toString().trim();\nconst text = userMessage.toLowerCase();\n\nconst sessionId =\n  chat.sessionId ||\n  chat.userId ||\n  chat.phoneNumber ||\n  \"no-session\";\n\n// Existing row from Supabase (if any)\nconst dbRow = supaItems || null;\nconst hasRow = !!dbRow;\n\n// Default state\nlet state = dbRow?.state || null;          // \"awaiting_choice\" | \"chatting\" | null\nlet preferredBot = dbRow?.preferred_bot || null;\n\n// MODE tells workflow what to do with this message\n// \"send_menu\" | \"save_choice\" | \"chat\"\nlet mode = \"chat\";\n\n// 1) If no row yet → first time user → send menu\nif (!hasRow) {\n  mode = \"send_menu\";\n  state = \"awaiting_choice\";\n}\n\n// 2) If we are waiting for user to choose a bot\nelse if (state === \"awaiting_choice\") {\n  // map user's reply to a bot (numbers OR words)\n  if (text === \"1\" || text.includes(\"disease\")) {\n    preferredBot = \"disease\";\n  } else if (text === \"2\" || text.includes(\"women\") || text.includes(\"nutrition\")) {\n    preferredBot = \"women_nutrition\";\n  } else if (text === \"3\" || text.includes(\"blood\") || text.includes(\"lab\")) {\n    preferredBot = \"blood_test\";\n  }\n\n  if (preferredBot) {\n    mode = \"save_choice\";   // we got a valid selection\n    state = \"chatting\";\n  } else {\n    // still wrong reply → ask again\n    mode = \"send_menu\";\n    state = \"awaiting_choice\";\n  }\n}\n\n// 3) If already chatting → normal chat flow\nelse {\n  mode = \"chat\";\n}\n\n// Output for next nodes\nreturn [\n  {\n    json: {\n      sessionId,\n      userMessage,\n      state,\n      preferredBot,\n      mode,\n      dbRow,\n    },\n  },\n];\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        112,
        -2272
      ],
