      "parameters": {
        "jsCode": "// Read Chat Trigger output safely\nconst chat = $node[\"When chat message received\"]?.json || {};\n\n// Extract details\nconst sessionId = chat.sessionId || \"no-session\";\nconst userMessage = chat.chatInput || \"\";\n\n// Get previous node output (if needed)\nconst previousOutput = $input.first()?.json?.output || null;\n\n// Return for next nodes\nreturn [\n  {\n    json: {\n      sessionId,\n      userMessage,\n      previousOutput,   // <-- this is valid\n    }\n  }\n];\n"
      },
