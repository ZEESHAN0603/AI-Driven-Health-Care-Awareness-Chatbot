{
  "name": "Multi-Bot RAG System HealthMate",
  "nodes": [
    {
      "parameters": {
        "jsCode": "// ---------- READ CURRENT MESSAGE ----------\nconst rawInput =\n  $json.userMessage ||\n  $json.userQuestion ||\n  $json.chatInput ||\n  \"\";\n\n// Normalise\nconst question = rawInput.toString().trim();\nconst text = question.toLowerCase();\n\n// DB status & row from previous node (if you need later)\nconst hasRow  = $json.dbHasRow === true;\nconst dbRow   = $json.dbRow || null;\n\n// ---------- CATEGORY HINT FOR AGENT ----------\nlet categoryHint = \"general\";\n\n// ❶ Disease & Symptoms\nif (\n  text.includes(\"disease\") ||\n  text.includes(\"symptom\") ||\n  text.includes(\"diagnose\") ||\n  text.includes(\"diagnosis\") ||\n  text.includes(\"infection\") ||\n  text.includes(\"fever\") ||\n  text.includes(\"cough\") ||\n  text.includes(\"cold\") ||\n  text.includes(\"pain\") ||\n  text.includes(\"risk\")\n) {\n  categoryHint = \"disease\";\n}\n\n// ❷ Women Nutrition & Maternal Health\nelse if (\n  text.includes(\"women\") ||\n  text.includes(\"woman\") ||\n  text.includes(\"pregnancy\") ||\n  text.includes(\"pregnant\") ||\n  text.includes(\"breastfeeding\") ||\n  text.includes(\"nutrition\") ||\n  text.includes(\"supplement\") ||\n  text.includes(\"iron deficiency\") ||\n  text.includes(\"calcium\") ||\n  text.includes(\"folic acid\") ||\n  text.includes(\"pcos\") ||\n  text.includes(\"period\") ||\n  text.includes(\"menstrual\") ||\n  text.includes(\"maternal\")\n) {\n  categoryHint = \"women_nutrition\";\n}\n\n// ❸ Blood Tests & Lab Results\nelse if (\n  text.includes(\"blood test\") ||\n  text.includes(\"test report\") ||\n  text.includes(\"lab report\") ||\n  text.includes(\"cbc\") ||\n  text.includes(\"lft\") ||\n  text.includes(\"kft\") ||\n  text.includes(\"hemoglobin\") ||\n  text.includes(\"platelet\") ||\n  text.includes(\"vitamin d\") ||\n  text.includes(\"vitamin b12\") ||\n  text.includes(\"thyroid\") ||\n  text.includes(\"tsh\") ||\n  text.includes(\"t3\") ||\n  text.includes(\"t4\") ||\n  text.includes(\"hba1c\")\n) {\n  categoryHint = \"blood_test\";\n}\n\n// Attach fields for Agent\n$json.cleanedQuestion = question;\n$json.categoryHint    = categoryHint;\n\n// Bundle everything for optional use in Agent/system prompt\n$json.agentInput = {\n  question,\n  categoryHint,\n  dbHasRow: hasRow,\n  profile: dbRow,\n  sessionId: $json.sessionId,\n};\n\n// Output item back to workflow\nreturn [{ json: $json }];\n"
      },
