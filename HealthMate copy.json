    {
      "parameters": {
        "jsCode": "// Get normalized message\nconst chat = $json || {};\nconst userMessage = (chat.userMessage || \"\").toString().trim();\nconst text = userMessage.toLowerCase();\n\n// Supabase result (single row)\nconst dbRow = $node[\"Get many rows\"]?.json || null;\nconst hasRow = !!dbRow;\n\n// session id from earlier\nconst sessionId = chat.sessionId || \"no-session\";\n\nlet state = dbRow?.state || null;          // \"awaiting_choice\" | \"chatting\" | null\nlet preferredBot = dbRow?.preferred_bot || null;\nlet mode = \"chat\";\n\n// 1) first time user → send menu\nif (!hasRow) {\n  mode = \"send_menu\";\n  state = \"awaiting_choice\";\n}\n\n// 2) waiting for bot choice\nelse if (state === \"awaiting_choice\") {\n  if (text === \"1\" || text.includes(\"disease\")) {\n    preferredBot = \"disease\";\n  } else if (text === \"2\" || text.includes(\"women\") || text.includes(\"nutrition\")) {\n    preferredBot = \"women_nutrition\";\n  } else if (text === \"3\" || text.includes(\"blood\") || text.includes(\"lab\")) {\n    preferredBot = \"blood_test\";\n  }\n\n  if (preferredBot) {\n    mode = \"save_choice\";\n    state = \"chatting\";\n  } else {\n    mode = \"send_menu\";\n    state = \"awaiting_choice\";\n  }\n}\n\n// 3) already chatting\nelse {\n  mode = \"chat\";\n}\n\nreturn [\n  {\n    json: {\n      sessionId,\n      userMessage,\n      state,\n      preferredBot,\n      mode,\n      dbRow,\n    },\n  },\n];\n"
      },
