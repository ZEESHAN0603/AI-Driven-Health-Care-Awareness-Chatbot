        "jsCode": "const places = $json.places || [];\n\nconst defaultLat = $input.first().json.body.Latitude;\nconst defaultLng = $input.first().json.body.Longitude;\n\nlet message = \"\";\n\nplaces.forEach((place, index) => {\n  const name = place.displayName?.text || \"Unknown Place\";\n  const address = place.formattedAddress || \"Address not available\";\n\n  // Always use DEFAULT latitude & longitude\n  const latitude = defaultLat;\n  const longitude = defaultLng;\n\n  message += `${index + 1}️⃣ ${name}\\n`;\n  message += `📍 Address: ${address}\\n`;\n  message += `📌 Location: ${latitude}, ${longitude}\\n\\n`;\n});\n\nreturn [\n  {\n    json: {\n      whatsappMessage: message.trim()\n    }\n  }\n];\n"
