      "parameters": {
        "jsCode": "const body = $json.body || {};\n\n// WhatsApp message text\nconst userMessage = (body.Body || \"\").toString().trim();\n\n// message type: \"text\" or \"location\"\nconst messageType = (body.MessageType || \"text\").toLowerCase();\n\n// use WhatsApp number as session id\nconst sessionId =\n  body.From || body.WaId || body.from || \"no-session\";\n\nreturn [\n  {\n    json: {\n      body,\n      userMessage,\n      messageType,\n      sessionId,\n    },\n  },\n];\n"
      },
