    {
      "parameters": {
        "jsCode": "// safe: use given items or fallback to empty array\nconst inputItems = (typeof items !== 'undefined' && items) ? items : [];\n\nconst out = [];\nconst now = new Date();\n\nfor (const it of inputItems) {\n  const r = it.json;\n\n  // Decide sendNow (example using next_reminders or times)\n  let sendNow = false;\n  if (r.next_reminders) {\n    const nr = new Date(r.next_reminders);\n    if (Math.abs(now - nr) <= 90 * 1000) sendNow = true;\n  } else if (r.times) {\n    const times = (r.times || '').split(',').map(s => s.trim()).filter(Boolean);\n    for (const t of times) {\n      const parts = t.split(':').map(x => parseInt(x,10));\n      if (parts.length >= 2) {\n        const candidate = new Date();\n        candidate.setHours(parts[0], parts[1], 0, 0);\n        if (Math.abs(now - candidate) <= 90 * 1000) { sendNow = true; break; }\n      }\n    }\n  }\n\n  if (sendNow) {\n    out.push({ json: {\n      reminder_id: r.reminder_id,\n      user_id: r.user_id,\n      user_name: r.user_name,\n      medicine_name: r.medicine_name,\n      dosage: r.dosage,\n      times: r.times,\n      next_reminders: r.next_reminders\n    }});\n  }\n}\n\nreturn out;\n"
      },
