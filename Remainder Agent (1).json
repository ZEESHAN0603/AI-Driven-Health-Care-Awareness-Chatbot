    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// Helper: convert \"7pm\" or \"7 pm\" to 24-hour \"19:00\"\nfunction convertTo24Hour(timeStr) {\n  timeStr = timeStr.toLowerCase().replace(\" \", \"\");\n  let hour = parseInt(timeStr);\n\n  if (timeStr.includes(\"pm\") && hour !== 12) hour += 12;\n  if (timeStr.includes(\"am\") && hour === 12) hour = 0;\n\n  return `${hour.toString().padStart(2, \"0\")}:00`;\n}\n\nfor (const item of items) {\n\n  const userMsg = item.json.user_message;    // Input from your LLM\n  const medName = item.json.medicine_name;   // Eg: \"dolo 650\"\n  const rawTime = item.json.time;            // Eg: \"7pm\"\n\n  // Convert to 24-hour time\n  const time24 = convertTo24Hour(rawTime);\n\n  // Create ISO next run time (today at that time)\n  const today = new Date();\n  const [hh, mm] = time24.split(\":\");\n\n  today.setHours(hh);\n  today.setMinutes(mm);\n  today.setSeconds(0);\n  today.setMilliseconds(0);\n\n  // ADD FIELDS FOR DB + NEXT WORKFLOW\n  item.json.message = `Take your ${medName} tablet`;\n  item.json.time24 = time24;\n  item.json.nextRunAt = today.toISOString();\n}\n\nreturn items;\n\n"
      },
