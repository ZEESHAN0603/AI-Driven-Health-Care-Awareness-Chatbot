{
  "name": "Remainder Agent",
  "nodes": [
    {
      "parameters": {
        "functionCode": "// Extract topic (medicine) + time (8am) + reminderAt (ISO datetime)\n\nreturn items.map(item => {\n  const j = item.json;\n\n  // message text: from originalText or message\n  const rawText = (j.originalText || j.message || \"\").toLowerCase();\n\n  // ---- Topic (after \"take \") ----\n  let topic = \"medicine\";\n  const topicMatch = rawText.match(/take\\s+([a-z\\s]+)/);\n  if (topicMatch) {\n    topic = topicMatch[1]\n      .replace(/\\s+at\\s+.*$/, \"\")   // remove \" at 8am\"\n      .trim();\n  }\n\n  // ---- Time parsing: \"at 8am\", \"at 8:30 pm\" etc. ----\n  let timeText = null;\n  let reminderAt = null;\n\n  const timeMatch = rawText.match(/at\\s+(\\d{1,2})(?::(\\d{2}))?\\s*(am|pm)?/);\n  if (timeMatch) {\n    let hour = parseInt(timeMatch[1], 10);\n    const minute = timeMatch[2] ? parseInt(timeMatch[2], 10) : 0;\n    const ampm = timeMatch[3] || \"\";\n\n    // 12h → 24h\n    hour = hour % 12;\n    if (ampm === \"pm\") hour += 12;\n\n    const now = new Date();\n    let dt = new Date(\n      now.getFullYear(),\n      now.getMonth(),\n      now.getDate(),\n      hour,\n      minute,\n      0,\n      0\n    );\n\n    // if time already passed today → tomorrow\n    if (dt <= now) {\n      dt.setDate(dt.getDate() + 1);\n    }\n\n    reminderAt = dt.toISOString();\n    timeText = timeMatch[0].replace(/^at\\s+/, \"\").trim(); // e.g. \"8am\"\n  }\n\n  return {\n    json: {\n      ...j,\n      topic,       // e.g. \"medicine\"\n      timeText,    // e.g. \"8am\"\n      reminderAt,  // ISO datetime to store in DB\n    },\n  };\n});\n"
      },
